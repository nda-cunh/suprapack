#!/bin/sh

# Terminal colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}Starting Suprapack uninstallation...${NC}"

# Remove configuration and symlinks
echo "Removing configuration files..."
[ -L "$HOME/.config/suprapack" ] && rm "$HOME/.config/suprapack" && echo "✓ Removed config symlink"
[ -f "$HOME/.suprapack_profile" ] && rm "$HOME/.suprapack_profile" && echo "✓ Removed .suprapack_profile"

# Refresh Desktop & MIME databases
echo "Refreshing system databases..."
if [ -d "$HOME/.local/share/mime" ]; then
    update-mime-database "$HOME/.local/share/mime" 2>/dev/null || true
fi
if [ -d "$HOME/.local/share/applications" ]; then
    update-desktop-database "$HOME/.local/share/applications" 2>/dev/null || true
fi

echo ""
echo "${GREEN}Successfully uninstalled Suprapack from your environment.${NC}"
